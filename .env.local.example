# .env.local — Configuración de credenciales FTP para upload_patch.ps1
# ⚠️  ESTE ARCHIVO NO SE SUBE A GIT (ver .gitignore)
# Copia este archivo como .env.local y completa tus credenciales reales.

# Servidor FTP de InfinityFree
FTP_HOST=ftpupload.net

# Usuario FTP (igual que el usuario de la base de datos MySQL)
FTP_USER=if0_42133638

# Contraseña FTP (la misma que configuraste al crear el hosting en InfinityFree)
FTP_PASS=TU_CONTRASEÑA_FTP_AQUI

# Directorio raíz del sitio en el servidor (no modificar salvo que tengas un subdominio)
FTP_REMOTEDIR=/htdocs
